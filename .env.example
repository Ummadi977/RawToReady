# ── LLM provider — set whichever you have ─────────────────────────────────────

# Gemini (default) — get a key at https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key_here
DATAFLOW_MODEL=gemini-2.0-flash

# OpenAI — uncomment to use instead
# OPENAI_API_KEY=your_openai_api_key_here
# DATAFLOW_MODEL=gpt-4o

# Anthropic — uncomment to use instead
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# DATAFLOW_MODEL=claude-sonnet-4-6

# ── Pipeline settings ──────────────────────────────────────────────────────────
DATAFLOW_OUTPUT_DIR=./output
DATAFLOW_LOG_LEVEL=INFO

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGSMITH_PROJECT=dataflow-agents
# LANGSMITH_TRACING=true
